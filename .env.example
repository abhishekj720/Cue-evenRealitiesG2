# TODO: add your Anthropic API key below.
# Get one at https://console.anthropic.com/settings/keys — free to create,
# but needs credits in Plans & Billing before the /v1/messages endpoint works.
#
# Then: cp .env.example .env  and paste your real key into .env (gitignored).
ANTHROPIC_API_KEY=sk-ant-XXXX-REPLACE-ME

# WebSocket bridge to the React plugin. 0.0.0.0 makes it reachable from a
# phone on the same LAN (real G2 demo); localhost-only works for simulator.
CUE_BRIDGE_HOST=0.0.0.0
CUE_BRIDGE_PORT=8765
